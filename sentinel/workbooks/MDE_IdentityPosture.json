{
  "$schema": "https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json",
  "fallbackResourceIds": [],
  "fromTemplateId": "sentinel-MDE_IdentityPosture",
  "items": [
    {
      "name": "header",
      "content": {
        "json": "# MDE Identity Posture\n\nMDI service account coverage, DC onboarding, alert threshold drift."
      },
      "type": 1
    },
    {
      "name": "parameters",
      "content": {
        "parameters": [
          {
            "value": {
              "durationMs": 86400000
            },
            "id": "tr",
            "name": "TimeRange",
            "version": "KqlParameterItem/1.0",
            "type": 4,
            "typeSettings": {
              "selectableValues": [
                {
                  "durationMs": 3600000
                },
                {
                  "durationMs": 86400000
                },
                {
                  "durationMs": 604800000
                },
                {
                  "durationMs": 2592000000
                }
              ]
            }
          }
        ],
        "queryType": 0,
        "style": "pills",
        "version": "KqlParameterItem/1.0"
      },
      "type": 9
    },
    {
      "name": "panel-1",
      "content": {
        "queryType": 0,
        "title": "Primary view",
        "size": 0,
        "query": "MDE_DCCoverage_CL | summarize arg_max(TimeGenerated, *) by EntityId | extend Covered = tostring(parse_json(RawJson).hasSensor) | summarize Coverage = countif(Covered == \"true\"), Total = count() | extend CoveragePct = todouble(Coverage) / todouble(Total) * 100",
        "version": "KqlItem/1.0"
      },
      "type": 3
    },
    {
      "name": "panel-2",
      "content": {
        "queryType": 0,
        "title": "Drift / trend",
        "size": 0,
        "query": "MDE_Drift_P5Identity(30d, 1d) | summarize Changes = count() by StreamName, bin(TimeGenerated, 1d) | render timechart",
        "version": "KqlItem/1.0"
      },
      "type": 3
    }
  ],
  "version": "Notebook/1.0"
}
