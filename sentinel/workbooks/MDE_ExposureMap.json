{
  "$schema": "https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json",
  "fallbackResourceIds": [],
  "fromTemplateId": "sentinel-MDE_ExposureMap",
  "items": [
    {
      "name": "header",
      "content": {
        "json": "# MDE Exposure Map\n\nXSPM attack paths, chokepoints, and exposure score trends."
      },
      "type": 1
    },
    {
      "name": "parameters",
      "content": {
        "parameters": [
          {
            "value": { "durationMs": 604800000 },
            "id": "tr",
            "name": "TimeRange",
            "version": "KqlParameterItem/1.0",
            "type": 4,
            "typeSettings": {
              "selectableValues": [
                {
                  "durationMs": 3600000
                },
                {
                  "durationMs": 86400000
                },
                {
                  "durationMs": 604800000
                },
                {
                  "durationMs": 2592000000
                }
              ]
            }
          }
        ],
        "queryType": 0,
        "style": "pills",
        "version": "KqlParameterItem/1.0"
      },
      "type": 9
    },
    {
      "name": "panel-1",
      "content": {
        "queryType": 0,
        "title": "Primary view",
        "size": 0,
        "query": "MDE_XspmAttackPaths_CL | summarize arg_max(TimeGenerated, *) by EntityId | extend EntryNode = tostring(parse_json(RawJson).entryNode), TargetNode = tostring(parse_json(RawJson).targetNode), Hops = toint(parse_json(RawJson).hops) | project EntryNode, TargetNode, Hops",
        "version": "KqlItem/1.0"
      },
      "type": 3
    },
    {
      "name": "panel-2",
      "content": {
        "queryType": 0,
        "title": "Drift / trend",
        "size": 0,
        "query": "MDE_ExposureSnapshots_CL | extend Score = todouble(parse_json(RawJson).score) | summarize AvgScore = avg(Score) by bin(TimeGenerated, 1d) | render timechart",
        "version": "KqlItem/1.0"
      },
      "type": 3
    }
  ],
  "version": "Notebook/1.0"
}
