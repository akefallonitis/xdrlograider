# Example env file for local online tests.
# Copy to tests/.env.local and fill in real values.
# tests/.env.local is gitignored — NEVER commit it.
#
# Usage:
#   cp tests/.env.local.example tests/.env.local
#   # edit tests/.env.local
#   pwsh ./tests/Run-Tests.ps1 -Category local-online

# --- Service account UPN ---
XDRLR_TEST_UPN=svc-xdrtest@your-tenant.onmicrosoft.com

# --- Auth method: 'CredentialsTotp', 'Passkey', or 'DirectCookies' ---
# DirectCookies is the fastest path for testing — no automation, just paste
# sccauth + XSRF-TOKEN from your browser. See tests/README.md for how to capture them.
XDRLR_TEST_AUTH_METHOD=DirectCookies

# --- Credentials+TOTP fields (if AUTH_METHOD=CredentialsTotp) ---
# Password: the service account's current password
XDRLR_TEST_PASSWORD=replace-with-real-password

# TOTP secret: Base32-encoded shared secret shown when enrolling Microsoft Authenticator
# (usually visible via "I can't scan the QR code" link during setup)
XDRLR_TEST_TOTP_SECRET=JBSWY3DPEHPK3PXPJBSWY3DPEHPK

# --- Passkey field (if AUTH_METHOD=Passkey) ---
# Path to a JSON file containing the software passkey
# Expected schema:
#   { "upn": "...", "credentialId": "<base64url>", "privateKeyPem": "-----BEGIN EC PRIVATE KEY-----\n...", "rpId": "login.microsoft.com" }
XDRLR_TEST_PASSKEY_PATH=./my-passkey.json

# --- DirectCookies fields (if AUTH_METHOD=DirectCookies) ---
# How to capture these (2 minute process, no code needed):
#   1. Log into https://security.microsoft.com in Chrome/Edge
#   2. Open DevTools (F12) → Application tab
#   3. Left sidebar: Storage → Cookies → https://security.microsoft.com
#   4. Find the row where Name = `sccauth` — copy the Value column
#   5. Find the row where Name = `XSRF-TOKEN` — copy the Value column
#   6. Paste below (these expire in ~1h; re-capture to run again)
XDRLR_TEST_SCCAUTH=paste-sccauth-cookie-value-here
XDRLR_TEST_XSRF_TOKEN=paste-XSRF-TOKEN-cookie-value-here

# --- Optional: target portal host (defaults to security.microsoft.com) ---
# XDRLR_TEST_PORTAL_HOST=security.microsoft.com

# --- Optional: explicit skip of certain test groups ---
# XDRLR_SKIP_SAMPLE_CALL=false
