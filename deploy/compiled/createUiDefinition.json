{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": false,
      "basics": {
        "description": "**XdrLogRaider** — Microsoft Sentinel data connector. Polls Microsoft Defender XDR portal-only endpoints and lands telemetry in 47 custom Log Analytics tables. Operators bring their own KQL parsers, hunting queries, analytic rules, and workbooks.\n\n**Prerequisite**: an existing Sentinel-enabled Log Analytics workspace. This template provisions the connector resources (Function App + Key Vault + Storage + DCE + DCRs + App Insights) and adds the custom tables + Data Connector card to your workspace (cross-RG supported).\n\n**After deploy**: run `./tools/Initialize-XdrLogRaiderAuth.ps1 -KeyVaultName <from-output>` to upload service-account auth secrets to Key Vault.",
        "subscription": {},
        "resourceGroup": {
          "allowExisting": true,
          "constraints": {
            "validations": [
              {
                "permission": "Microsoft.Resources/deployments/write",
                "message": "You need Contributor or Owner on the target resource group to deploy."
              }
            ]
          }
        },
        "location": {
          "label": "Connector region",
          "toolTip": "Region for connector resources."
        }
      }
    },
    "basics": [
      {
        "name": "projectPrefix",
        "type": "Microsoft.Common.TextBox",
        "label": "Project prefix",
        "toolTip": "3-12 lowercase alphanumeric. Used as the prefix for all resource names.",
        "defaultValue": "xdrlr",
        "constraints": {
          "required": true,
          "regex": "^[a-z0-9]{3,12}$",
          "validationMessage": "3-12 lowercase alphanumeric characters"
        }
      },
      {
        "name": "env",
        "type": "Microsoft.Common.DropDown",
        "label": "Environment",
        "toolTip": "Environment tag.",
        "defaultValue": "prod",
        "constraints": {
          "required": true,
          "allowedValues": [
            { "label": "Production", "value": "prod" },
            { "label": "Staging",    "value": "staging" },
            { "label": "Development", "value": "dev" }
          ]
        }
      },
      {
        "name": "infoServiceAccount",
        "type": "Microsoft.Common.InfoBox",
        "visible": true,
        "options": {
          "icon": "Info",
          "text": "Use a dedicated read-only Entra service account (Security Reader + Defender XDR Analyst). Paste its UPN below; upload its credentials to Key Vault after deploy."
        }
      }
    ],
    "steps": [
      {
        "name": "workspaceSettings",
        "label": "Sentinel workspace",
        "subLabel": {
          "preValidation": "Point the connector at your existing Sentinel workspace",
          "postValidation": "OK"
        },
        "bladeTitle": "Target workspace",
        "elements": [
          {
            "name": "infoWorkspacePrereq",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Info",
              "text": "Required role on the workspace: Log Analytics Contributor (or Contributor / Owner)."
            }
          },
          {
            "name": "existingWorkspace",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "Sentinel workspace",
            "toolTip": "Existing Sentinel-enabled Log Analytics workspace. Workspace region auto-populates below.",
            "resourceType": "Microsoft.OperationalInsights/workspaces",
            "options": {
              "filter": {
                "subscription": "all",
                "location": "all"
              }
            }
          },
          {
            "name": "workspaceInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[not(empty(steps('workspaceSettings').existingWorkspace.id))]",
            "options": {
              "icon": "Info",
              "text": "[concat('Selected: ', steps('workspaceSettings').existingWorkspace.name, ' (region: ', steps('workspaceSettings').existingWorkspace.location, ').')]"
            }
          },
          {
            "name": "workspaceLocationOverride",
            "type": "Microsoft.Common.DropDown",
            "label": "Workspace region (override)",
            "toolTip": "Auto-detected from the selected workspace. Override only if auto-detection is wrong.",
            "defaultValue": "",
            "visible": "[not(empty(steps('workspaceSettings').existingWorkspace.id))]",
            "constraints": {
              "required": false,
              "allowedValues": [
                { "label": "Auto-detect from workspace (recommended)", "value": "" },
                { "label": "East US",            "value": "eastus" },
                { "label": "East US 2",          "value": "eastus2" },
                { "label": "West US",            "value": "westus" },
                { "label": "West US 2",          "value": "westus2" },
                { "label": "West US 3",          "value": "westus3" },
                { "label": "Central US",         "value": "centralus" },
                { "label": "North Central US",   "value": "northcentralus" },
                { "label": "South Central US",   "value": "southcentralus" },
                { "label": "Canada Central",     "value": "canadacentral" },
                { "label": "North Europe",       "value": "northeurope" },
                { "label": "West Europe",        "value": "westeurope" },
                { "label": "UK South",           "value": "uksouth" },
                { "label": "UK West",            "value": "ukwest" },
                { "label": "France Central",     "value": "francecentral" },
                { "label": "Germany West Central","value": "germanywestcentral" },
                { "label": "Switzerland North",  "value": "switzerlandnorth" },
                { "label": "Sweden Central",     "value": "swedencentral" },
                { "label": "Norway East",        "value": "norwayeast" },
                { "label": "Australia East",     "value": "australiaeast" },
                { "label": "Australia Southeast","value": "australiasoutheast" },
                { "label": "Southeast Asia",     "value": "southeastasia" },
                { "label": "East Asia",          "value": "eastasia" },
                { "label": "Japan East",         "value": "japaneast" },
                { "label": "Japan West",         "value": "japanwest" },
                { "label": "Korea Central",      "value": "koreacentral" },
                { "label": "India Central",      "value": "centralindia" },
                { "label": "UAE North",          "value": "uaenorth" },
                { "label": "South Africa North", "value": "southafricanorth" },
                { "label": "Brazil South",       "value": "brazilsouth" }
              ]
            }
          }
        ]
      },
      {
        "name": "authSettings",
        "label": "Authentication",
        "subLabel": {
          "preValidation": "Portal sign-in method",
          "postValidation": "OK"
        },
        "bladeTitle": "Portal authentication",
        "elements": [
          {
            "name": "serviceAccountUpn",
            "type": "Microsoft.Common.TextBox",
            "label": "Service account UPN",
            "toolTip": "UPN of the read-only Entra service account.",
            "defaultValue": "",
            "constraints": {
              "required": true,
              "regex": "^[^@]+@[^@]+\\.[^@]+$",
              "validationMessage": "Valid UPN (user@domain.tld)"
            }
          },
          {
            "name": "authMethod",
            "type": "Microsoft.Common.DropDown",
            "label": "Auth method",
            "toolTip": "Portal sign-in method.",
            "defaultValue": "Credentials + TOTP",
            "constraints": {
              "required": true,
              "allowedValues": [
                { "label": "Credentials + TOTP", "value": "credentials_totp" },
                { "label": "Software Passkey",   "value": "passkey" }
              ]
            }
          },
          {
            "name": "uploadSecretsNow",
            "type": "Microsoft.Common.OptionsGroup",
            "label": "Upload auth secrets",
            "toolTip": "Upload via wizard writes secrets to Key Vault during deploy. Upload via post-deploy script lets you upload them later via Initialize-XdrLogRaiderAuth.ps1.",
            "defaultValue": "Upload via wizard",
            "constraints": {
              "required": true,
              "allowedValues": [
                { "label": "Upload via wizard",            "value": "wizard" },
                { "label": "Upload via post-deploy script", "value": "script" }
              ]
            }
          },
          {
            "name": "servicePassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": { "password": "Service account password", "confirmPassword": "Confirm password" },
            "toolTip": "Service account password.",
            "visible": "[and(equals(steps('authSettings').authMethod, 'credentials_totp'), equals(steps('authSettings').uploadSecretsNow, 'wizard'))]",
            "options": { "hideConfirmation": false },
            "constraints": { "required": true, "regex": ".+", "validationMessage": "Password is required when uploading via wizard" }
          },
          {
            "name": "totpSeed",
            "type": "Microsoft.Common.PasswordBox",
            "label": { "password": "TOTP Base32 secret", "confirmPassword": "Confirm TOTP secret" },
            "toolTip": "Base32-encoded TOTP seed. Leave blank if the service account is exempt from MFA.",
            "visible": "[and(equals(steps('authSettings').authMethod, 'credentials_totp'), equals(steps('authSettings').uploadSecretsNow, 'wizard'))]",
            "options": { "hideConfirmation": true },
            "constraints": { "required": false, "regex": "^([A-Za-z2-7=\\s]{16,})?$", "validationMessage": "Base32 only (A-Z, 2-7), 16+ chars or empty" }
          },
          {
            "name": "passkeyJson",
            "type": "Microsoft.Common.TextBox",
            "label": "Passkey JSON",
            "toolTip": "Passkey JSON containing upn, credentialId, privateKeyPem.",
            "multiLine": true,
            "visible": "[and(equals(steps('authSettings').authMethod, 'passkey'), equals(steps('authSettings').uploadSecretsNow, 'wizard'))]",
            "constraints": { "required": true, "regex": "^\\s*\\{[\\s\\S]+\\}\\s*$", "validationMessage": "Must be a JSON object containing upn, credentialId, privateKeyPem" }
          },
          {
            "name": "infoPostDeploy",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[equals(steps('authSettings').uploadSecretsNow, 'script')]",
            "options": {
              "icon": "Info",
              "text": "Run ./tools/Initialize-XdrLogRaiderAuth.ps1 -KeyVaultName <from-output> after deploy completes."
            }
          },
          {
            "name": "infoUploadNow",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[equals(steps('authSettings').uploadSecretsNow, 'wizard')]",
            "options": {
              "icon": "Info",
              "text": "Secrets are written to Key Vault as part of the ARM deploy."
            }
          }
        ]
      },
      {
        "name": "advanced",
        "label": "Advanced",
        "subLabel": {
          "preValidation": "Optional overrides",
          "postValidation": "OK"
        },
        "bladeTitle": "Advanced settings",
        "elements": [
          {
            "name": "restrictPublicNetwork",
            "type": "Microsoft.Common.CheckBox",
            "label": "Restrict public network access",
            "toolTip": "Restrict public network access on Storage, Key Vault, and Application Insights.",
            "defaultValue": false
          },
          {
            "name": "enableKeyVaultDiagnostics",
            "type": "Microsoft.Common.CheckBox",
            "label": "Key Vault audit logging",
            "toolTip": "Send Key Vault audit logs to the Sentinel workspace for credential-access forensics.",
            "defaultValue": true
          },
          {
            "name": "githubRepo",
            "type": "Microsoft.Common.TextBox",
            "label": "GitHub repo (owner/name)",
            "toolTip": "GitHub repo (owner/name) hosting the Function App release.",
            "defaultValue": "akefallonitis/xdrlograider",
            "constraints": {
              "required": true,
              "regex": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$",
              "validationMessage": "Format: <owner>/<repo>"
            }
          }
        ]
      },
      {
        "name": "postDeploy",
        "label": "Post-deploy verification",
        "subLabel": {
          "preValidation": "Auth setup + verify guidance",
          "postValidation": "OK"
        },
        "bladeTitle": "Post-deploy verification",
        "elements": [
          {
            "name": "infoPostDeploy",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Info",
              "text": "After deployment completes, run two operator-facing scripts to (1) seed the service account credentials in Key Vault, and (2) verify connector health.\\n\\nStep 1 — Seed auth secrets in Key Vault:\\n  pwsh ./tools/Initialize-XdrLogRaiderAuth.ps1 -KeyVaultName <kv-name>\\n\\nStep 2 — Verify connector health (after ~10 min for first poll cycle):\\n  pwsh ./tools/Test-ConnectorHealth.ps1\\n\\nExpected: HEALTHY verdict + heartbeat freshness < 15 min + zero AuthChain.* exceptions."
            }
          },
          {
            "name": "infoEnableRules",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Warning",
              "text": "All 18 analytic rules ship DISABLED per Microsoft Sentinel best practice. After verification, enable the 4 XdrOps-* operational rules in Sentinel UI:\\n  • XdrOps-ConnectorStaleStream — alerts on stream ingest stalls\\n  • XdrOps-AuthChainFailure — alerts on auth-chain anomalies\\n  • XdrOps-DlqDepthAlert — alerts on DLQ backpressure\\n  • XdrOps-ServiceAccountAnomalousSignIn — uses the SERVICE_ACCOUNT_UPN you provided in step 2 to detect sign-in anomalies\\n\\nThe 14 detection rules are operator-tunable per environment; review then enable selectively."
            }
          },
          {
            "name": "infoSecurity",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Info",
              "text": "Verify supply-chain integrity: all release artifacts (function-app.zip, mainTemplate.json, sentinelContent.json, createUiDefinition.json, solution-*.zip, sbom.spdx.json) are Sigstore-cosign signed.\\n\\nVerification command:\\n  cosign verify-blob --certificate-identity-regexp 'akefallonitis' --certificate-oidc-issuer 'https://token.actions.githubusercontent.com' --signature <artifact>.sig --bundle <artifact>.bundle <artifact>"
            }
          }
        ]
      }
    ],
    "outputs": {
      "projectPrefix":         "[basics('projectPrefix')]",
      "env":                   "[basics('env')]",
      "connectorLocation":     "[location()]",
      "existingWorkspaceId":   "[steps('workspaceSettings').existingWorkspace.id]",
      "workspaceLocation":     "[if(empty(steps('workspaceSettings').workspaceLocationOverride), steps('workspaceSettings').existingWorkspace.location, steps('workspaceSettings').workspaceLocationOverride)]",
      "serviceAccountUpn":     "[steps('authSettings').serviceAccountUpn]",
      "authMethod":            "[steps('authSettings').authMethod]",
      "servicePassword":       "[if(and(equals(steps('authSettings').authMethod, 'credentials_totp'), equals(steps('authSettings').uploadSecretsNow, 'wizard')), steps('authSettings').servicePassword, '')]",
      "totpSeed":              "[if(and(equals(steps('authSettings').authMethod, 'credentials_totp'), equals(steps('authSettings').uploadSecretsNow, 'wizard')), steps('authSettings').totpSeed, '')]",
      "passkeyJson":           "[if(and(equals(steps('authSettings').authMethod, 'passkey'), equals(steps('authSettings').uploadSecretsNow, 'wizard')), steps('authSettings').passkeyJson, '')]",
      "restrictPublicNetwork":   "[steps('advanced').restrictPublicNetwork]",
      "enableKeyVaultDiagnostics":"[steps('advanced').enableKeyVaultDiagnostics]",
      "githubRepo":              "[steps('advanced').githubRepo]"
    }
  }
}
